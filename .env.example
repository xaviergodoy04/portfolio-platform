# Copiá este archivo como .env y completá con tus valores:
#   cp .env.example .env

# --- IBKR Flex Query (opcional) ---
# Solo si tenés cuenta en Interactive Brokers
# IB Client Portal > Reports > Flex Queries > Create
IBKR_FLEX_TOKEN=
IBKR_FLEX_QUERY_ID=

# --- Proveedor de IA ---
# "groq" (gratis) | "anthropic" (pago) | "auto" (prueba groq, fallback anthropic)
AI_PROVIDER=auto

# --- Groq (gratis) ---
# Registrate en https://console.groq.com/keys
GROQ_API_KEY=

# --- Anthropic (pago, opcional) ---
# Registrate en https://console.anthropic.com/
ANTHROPIC_API_KEY=
